{
  // Managed by Home Manager.
  // Runtime secrets are loaded from ${OPENCLAW_STATE_DIR}/.env.
  "env": {
    "shellEnv": {
      "enabled": true,
      "timeoutMs": 15000
    }
  },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },

  "agents": {
    "defaults": {
      "workspace": "${OPENCLAW_STATE_DIR}/workspace",
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": ["openai-codex/gpt-5.3-codex", "gemini-3.1-pro-preview"]
      },
      "subagents": {
        "model": "openai-codex/gpt-5.3-codex",
        "maxConcurrent": 2,
        "maxSpawnDepth": 2
      },
      "memorySearch": {
        "enabled": true
      },
      "maxConcurrent": 3,
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Devi",
        "subagents": {
          "allowAgents": ["coder"]
        },
        "tools": {
          // Force coding execution through the dedicated coder agent.
          "deny": ["group:fs", "group:runtime"]
        }
      },
      {
        "id": "coder",
        "name": "Coder",
        "model": "openai-codex/gpt-5.3-codex",
        "tools": {
          "profile": "coding",
          "deny": ["browser", "canvas", "nodes", "cron"]
        }
      }
    ]
  },

  "bindings": [{ "agentId": "main", "match": { "channel": "discord" } }],

  "channels": {
    "defaults": {
      "groupPolicy": "allowlist"
    },
    "discord": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "899754770343030824",
        "1289613951310499903",
        "132541484321865728",
        "492830492379316254"
      ],
      "groupPolicy": "open",
      "allowBots": false,
      "historyLimit": 50
    }
  },

  "commands": {
    "native": "auto",
    "text": true,
    "config": false,
    "debug": false,
    "restart": false
  },

  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "${OPENCLAW_HOOKS_TOKEN}"
  },

  "tools": {
    "profile": "full",
    "exec": {
      "backgroundMs": 10000,
      "timeoutSec": 1800,
      "notifyOnExit": true,
      "notifyOnExitEmptySuccess": false
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "discord": ["899754770343030824"]
      }
    }
  }
}
